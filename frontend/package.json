{
    "name": "frontend",
    "version": "1.0.0",
    "description": "DieCastCollectionTracker frontend (TypeScript, Vite, MUI, TanStack Query)",
    "private": true,
    "scripts": {
        "start": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
        "typecheck": "tsc --noEmit",
        "test": "cross-env NODE_OPTIONS=--no-experimental-webstorage vitest run",
        "test:watch": "cross-env NODE_OPTIONS=--no-experimental-webstorage vitest",
        "test:coverage": "cross-env NODE_OPTIONS=--no-experimental-webstorage vitest run --coverage",
        "icons": "pwa-assets-generator"
    },
    "dependencies": {
        "@emotion/react": "^11.11.3",
        "@emotion/styled": "^11.11.0",
        "@fontsource/roboto": "^5.0.8",
        "@material/material-color-utilities": "^0.4.0",
        "@mui/icons-material": "^6.1.0",
        "@mui/material": "^6.1.0",
        "@tanstack/query-async-storage-persister": "^5.101.2",
        "@tanstack/query-persist-client-core": "^5.101.2",
        "@tanstack/react-query": "^5.59.0",
        "@tanstack/react-query-persist-client": "^5.101.2",
        "@tanstack/react-virtual": "^3.14.5",
        "axios": "^1.7.7",
        "idb-keyval": "^6.2.6",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-router-dom": "^6.21.1",
        "react-toastify": "^10.0.5"
    },
    "devDependencies": {
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "@typescript-eslint/eslint-plugin": "^7.18.0",
        "@typescript-eslint/parser": "^7.18.0",
        "@vite-pwa/assets-generator": "^1.0.2",
        "@vitejs/plugin-react": "^4.3.1",
        "@vitest/coverage-v8": "^2.0.5",
        "cross-env": "^7.0.3",
        "eslint": "^8.56.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-react": "^7.35.0",
        "eslint-plugin-react-hooks": "^4.6.2",
        "jsdom": "^25.0.0",
        "typescript": "^5.5.4",
        "vite": "^5.4.2",
        "vite-plugin-pwa": "^1.3.0",
        "vitest": "^2.0.5"
